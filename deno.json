{
    "version": "0.0.1",
    "type": "module",
    "tasks": {
        "dev": "deno run -A --node-modules-dir npm:vite",
        "build": "deno run -A --node-modules-dir npm:vite build",
        "preview": "deno run -A --node-modules-dir npm:vite preview",
        "serve": "deno run --allow-net --allow-read jsr:@std/http@1/file-server dist/",
        "prepare": "deno run -A npm:@sveltejs/kit sync",
        "check": "deno run -A npm:@sveltejs/kit sync && deno run -A npm:svelte-check --tsconfig ./tsconfig.json"
    },
    "compilerOptions": {
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable",
            "denoNs",
            "deno.window",
            "deno.unstable"
        ]
    },
    "imports": {
        "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
        "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
        "@sveltejs/adapter-node": "npm:@sveltejs/adapter-node@^5.5.1",
        "@sveltejs/kit": "npm:@sveltejs/kit@^2.50.0",
        "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^6.2.0",
        "osu-api-v2-js": "npm:osu-api-v2-js@^3.0.0",
        "osu-api-v2-js/": "npm:osu-api-v2-js@^3.0.0/",
        "svelte": "npm:svelte@^5.38.10",
        "svelte/": "npm:svelte@^5.38.10/",
        "svelte-check": "npm:svelte-check@^4.3.5",
        "vite": "npm:vite@^7.1.5",
        "@libsql/client": "npm:@libsql/client@^0.17.0",
        "drizzle-kit": "npm:drizzle-kit@^0.31.8",
        "drizzle-orm": "npm:drizzle-orm@^0.45.1"
    },
    "nodeModulesDir": "auto",
    "unstable": ["sloppy-imports"],
    "allowScripts": {
        "allow": [],
        "deny": [
            "npm:better-sqlite3@12.6.2",
            "npm:esbuild@0.27.2",
            "npm:svelte-kit@1.2.0"
        ]
    }
}
